# Canonical public URL for Kangent, used only in production builds for
# things that can't be derived from the request (OpenGraph/canonical meta,
# sitemaps, etc.). In dev, everything is derived from the request origin,
# so you can leave this unset locally.
#
# Required when building for production. `pnpm build` fails if unset.
# Examples:
#   VITE_KANGENT_PUBLIC_URL=https://kangent-web.<your-account>.workers.dev
#   VITE_KANGENT_PUBLIC_URL=https://kangent.app
VITE_KANGENT_PUBLIC_URL=
